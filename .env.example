# ============================================================
# LawME — environment variable NAMES and descriptions only.
# NEVER put real values in this file. Copy to .env.local for
# local development (.env* is git-ignored) and fill values from
# the Supabase / Vercel dashboards or `vercel env pull`.
#
# Naming law: anything prefixed NEXT_PUBLIC_ ships to the
# browser. Server-only secrets must NEVER carry that prefix.
# ============================================================

# ── Supabase · public (browser-safe) ────────────────────────
# Project URL of the LawME **development** project.
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (anon) key — safe for the browser; RLS is the guard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase · server-only secrets (NEVER NEXT_PUBLIC_) ─────
# Service-role key — bypasses RLS. Server code only. Production value
# lives only in Vercel env (Production scope) and 1Password.
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token for the Supabase CLI (db:types, link).
# Set in your shell profile, not in project files.
SUPABASE_ACCESS_TOKEN=
# Direct database URL for migration tooling (server/CI only).
SUPABASE_DB_URL=

# ── Capability 1 · Matter document storage (server-only) ────
# Explicit storage mode. "supabase_dev" = durable Development persistence and
# NEVER falls back to memory (fails clearly if a credential is missing).
# Anything else / unset = in-memory dev adapter (local only).
LAWME_DOCUMENT_STORAGE_MODE=
# The Development project ref the server is bound to (guards against writing to
# the wrong project; must match the Supabase URL). Value: udispadsbxqicmawqcuk.
LAWME_SUPABASE_PROJECT_REF=
# Dedicated HMAC secret for short-lived document-preview tokens. SERVER-ONLY —
# never NEXT_PUBLIC. Minimum 32 characters, high entropy. There is NO fallback:
# preview signing fails closed if this is missing or too weak (it does NOT reuse
# the service-role key or any other secret). Generate e.g.: openssl rand -hex 32
LAWME_DOCUMENT_PREVIEW_SIGNING_SECRET=

# ── Application ─────────────────────────────────────────────
# Canonical app URL per environment (local: http://localhost:3000).
NEXT_PUBLIC_APP_URL=

# ── Vercel (set automatically by Vercel at build/runtime) ───
# Documented for reference; do not set manually.
# VERCEL_ENV / VERCEL_URL / VERCEL_GIT_COMMIT_SHA

# ── Future · AI providers (server-only) ─────────────────────
# דינו's model access. Server-only.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Future · WhatsApp (server-only) ─────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Future · Email (server-only) ────────────────────────────
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=

# ── Future · Calendar integrations (server-only) ────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Future · Webhooks (server-only) ─────────────────────────
WEBHOOK_SIGNING_SECRET=

# ── Observability (server-only unless stated) ───────────────
SENTRY_DSN=
# Browser-side DSN, if/when client monitoring is enabled:
NEXT_PUBLIC_SENTRY_DSN=

# ── Environment scoping guide ───────────────────────────────
# Development / Preview: development Supabase project values.
# Production: production Supabase project values (to be created —
# see docs/setup/ENVIRONMENT_MATRIX.md). Secrets differ per scope
# in Vercel; never share the service-role key across scopes.
